# Global platform for the project. Matches IPHONEOS_DEPLOYMENT_TARGET in the Xcode project.
# NOTE: Sign in with Apple's native flow needs iOS 13+; on iOS 12 devices the Apple button is
# hidden (gated by SignInWithApple.isAvailable() + kAppleSignInEnabled) — see lib/club/auth.
# If any pod raises its own minimum above 12.0 on the first `pod install`, bump this line to match.
platform :ios, '12.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # The Rust engine, vendored as a static xcframework built by ../build_ios.sh.
  # Resolvable only after that script has produced MakapixFFI.xcframework.
  pod 'makapix_ffi', :path => '.'

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # DynamicLibrary.process() (engine_ffi.dart on iOS) resolves the Rust symbols by name
    # at runtime. Because nothing in the Swift/ObjC Runner references them at LINK time, the
    # linker would dead-strip the whole static archive. -force_load keeps every symbol.
    #
    # RISK R2 (docs/ios-release/PLAN.md §6): the exact on-disk path of the vendored static
    # lib is confirmed on the first Mac build (Phase 2). CocoaPods stages xcframework slices
    # under $(PODS_XCFRAMEWORKS_BUILD_DIR)/makapix_ffi/. If mkpx_run et al. come back null
    # from DynamicLibrary.process(), verify this path (or point it at the built .a) on the Mac.
    if target.name == 'Runner'
      target.build_configurations.each do |config|
        config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
        config.build_settings['OTHER_LDFLAGS'] << '-force_load'
        config.build_settings['OTHER_LDFLAGS'] << '$(PODS_XCFRAMEWORKS_BUILD_DIR)/makapix_ffi/libmakapix_ffi.a'
      end
    end
  end
end
