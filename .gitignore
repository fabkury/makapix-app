# ---- Rust build output ----
/target
**/target

# ---- Harness artifacts (rendered PNGs, diffs, dumps) ----
target/mkpx-artifacts/
*.tmp

# ---- Flutter build output (also covered by app/**/.gitignore) ----
app/build/
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies

# ---- Flutter-generated plugin registrants ----
# Regenerated from pubspec by `flutter` on every build/pub-get; not source.
**/generated_plugin_registrant.cc
**/generated_plugin_registrant.h
**/generated_plugins.cmake

# ---- Generated cross-compiled engine libraries ----
# Rebuilt from the Rust source by build_android.ps1 (cargo-ndk); not source.
app/android/app/src/main/jniLibs/

# ---- Mock Makapix Club server output ----
tools/uploads/

# ---- Read-only upstream clone of the Makapix Club server (reference only) ----
# A throwaway clone of https://github.com/fabkury/makapix used to spec the
# Club integration (see SPEC-CLUB.md). Never committed into this repo.
reference/

# ---- Android signing secrets — NEVER commit ----
# The upload/release keystore and the properties file that holds its passwords.
# Losing/leaking these compromises the app's signing identity.
*.jks
*.keystore
key.properties
app/android/key.properties
inbox/keystore/

# ---- Google Play publisher service-account key — secret, NEVER commit ----
# Used by tools/play_publish.py / release_android.ps1 to upload AABs to Play
# (see docs/play-release.md). Grants release access to the Play listing.
app/android/play-service-account.json

# ---- Firebase Admin service-account key — secret, NEVER commit ----
# Downloaded from Firebase → Project settings → Service accounts. Used by the
# SERVER (via its vault) to send FCM pushes; must never enter this repo.
*firebase-adminsdk*.json

# ---- Google Services config (Firebase) — carries the project's Android API key ----
# Kept out of the public repo. Copy google-services.json.example -> google-services.json
# and fill in real values locally. Dormant today (no google-services Gradle plugin applied
# and no Firebase packages), so a fresh checkout still builds without it.
app/android/app/google-services.json

# ---- Private design specs — kept local, NOT published ----
# The editor-engine spec (SPEC.md) and the Club/server-contract spec (SPEC-CLUB.md) are
# intentionally not part of the public repo. They stay on disk for local development;
# do not re-add them to git.
/SPEC.md
/SPEC-CLUB.md

# ---- Local working area (drafts + machine-local secrets; never committed) ----
# Scratch dir for in-progress notes and downloaded secrets (firebase/, keystore/).
inbox/

# ---- Local Claude Code state (machine/user-specific) ----
.claude/

# ---- Python bytecode (tools/) ----
__pycache__/

# ---- Editor/OS noise ----
.idea/
.vscode/
*.iml
Thumbs.db
.DS_Store

# NOTE: Cargo.lock IS committed (this is an application workspace).
